// Cadence-Secrets.xcconfig — committed with EMPTY placeholders only.
//
// Real keys live locally and stay out of commits via `skip-worktree`:
//   git update-index --skip-worktree Cadence/Cadence-Secrets.xcconfig
//
// To verify the flag is set: `git ls-files -v | grep '^S'` should list this file.
// To temporarily un-skip (e.g. to add a new key as an empty placeholder):
//   git update-index --no-skip-worktree Cadence/Cadence-Secrets.xcconfig
//   # edit, commit the empty-placeholder change
//   git update-index --skip-worktree Cadence/Cadence-Secrets.xcconfig
//
// If a real key ever surfaces in `git status`, rotate at the provider
// (Langfuse / OpenRouter) rather than trying to scrub git history.
//
// Each value flows into Info.plist via $(VAR) substitution and is read at
// runtime by AppConfig.swift. Empty/placeholder values surface a
// "Build-time config missing" screen at launch.

LANGFUSE_PUBLIC_KEY =
LANGFUSE_SECRET_KEY =

// `://` and `/` aren't allowed in xcconfig values without escaping. Use the
// // → //$()/ trick so xcconfig doesn't treat the // as a comment.
LANGFUSE_HOST = https:/$()/cloud.langfuse.com

OPENROUTER_API_KEY =
