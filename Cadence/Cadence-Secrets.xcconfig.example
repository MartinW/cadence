// Cadence-Secrets.xcconfig — copy this file to `Cadence-Secrets.xcconfig`
// (no .example suffix) and fill in your real values. The real file is
// gitignored; this template is committed.
//
// Each value flows into Info.plist via $(VAR) substitution and is read at
// runtime by AppConfig.swift. Build-time injection means there's no
// in-app onboarding flow — the simulator starts up with a working list.

LANGFUSE_PUBLIC_KEY = pk-lf-...
LANGFUSE_SECRET_KEY = sk-lf-...

// `://` and `/` aren't allowed in xcconfig values without escaping. We use
// the // → //$()/ trick so xcconfig doesn't treat the // as a comment.
LANGFUSE_HOST = https:/$()/cloud.langfuse.com

OPENROUTER_API_KEY = sk-or-v1-...
